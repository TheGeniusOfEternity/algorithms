  "scripts": {
    "build": "npx tsc -p tsconfig.json",
    "build:full": "node scripts/build.ts",
    "test": "jest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "prepare": "husky"
